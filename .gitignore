# Reference materials (large binaries — keep locally, not in repo)
ref/
notes/

# Binary files in root (shouldn't be any after cleanup, but just in case)
*.pdf
*.docx
*.png
*.jpg
*.jpeg

# EXCEPTION: per-chapter NotebookLM slide decks ship with the site
!blog/slides/**
!hugo-site/static/blog/slides/**

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo

# FUSE hidden files
blog/.fuse_hidden*
.gstack/

# Newsletter pipeline
newsletter/.env
newsletter/briefs/
newsletter/drafts/
newsletter/blog-index.json
newsletter/node_modules/
newsletter/package-lock.json

# Environment variables (sensitive!)
.env
.env.local
.env.*.local

# Deploy artifacts (large zip bundles produced by build/Netlify — never commit)
deploy-*.zip
*.zip

# Node modules (any location)
node_modules/
