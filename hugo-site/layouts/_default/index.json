{{- $pages := where site.RegularPages "Section" "blog" -}}
[
{{- range $i, $p := $pages }}
{{- if $i }},{{ end }}
{
  "title": {{ $p.Title | jsonify }},
  "url": {{ $p.Permalink | jsonify }},
  "description": {{ $p.Description | jsonify }},
  "category": {{ $p.Params.category | default "" | jsonify }},
  "content": {{ $p.Plain | truncate 500 | jsonify }}
}
{{- end }}
]
